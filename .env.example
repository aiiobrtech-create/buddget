# App unificado (API + frontend) na porta 4072.
PORT=4072
NODE_ENV=development

# --- Postgres / Supabase ----------------------------------------------------
# db.<ref>.supabase.co = conexão DIRETA (IPv6). Funciona no PC com IPv6.
# VPS Hostinger (IPv4) PRECISA do Shared Pooler:
#
#   No dashboard Supabase → botão Connect → Session pooler
#   Host algo como: aws-0-us-east-1.pooler.supabase.com
#   Usuário: postgres.<project-ref>
#   Porta: 5432
#
# Cole as URIs do Connect (recomendado na VPS):
# DATABASE_URL=postgresql://postgres.[REF]:[SENHA]@aws-0-<REGIAO>.pooler.supabase.com:5432/postgres?sslmode=require
# DIRECT_URL=postgresql://postgres.[REF]:[SENHA]@aws-0-<REGIAO>.pooler.supabase.com:5432/postgres?sslmode=require
#
# Alternativa: manter db.* no .env e definir só o host do pooler (o app reescreve):
# SUPABASE_POOLER_HOST=aws-0-<REGIAO>.pooler.supabase.com
# SUPABASE_POOLER_MODE=session
#
# Docs: https://supabase.com/docs/guides/database/connecting-to-postgres

SUPABASE_POOLER_HOST=
SUPABASE_POOLER_MODE=session

DATABASE_URL=
DIRECT_URL=

# Diagnóstico: curl http://127.0.0.1:4072/health/db   ou   npx tsx scripts/check-db.ts

JWT_SECRET=change_me_access_16c
JWT_REFRESH_SECRET=change_me_refresh_16ch
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET_IMPORTS=buddget-imports
SUPABASE_STORAGE_BUCKET_EXPORTS=buddget-exports
SUPABASE_STORAGE_BUCKET_ATTACHMENTS=buddget-attachments
BCRYPT_SALT_ROUNDS=12
