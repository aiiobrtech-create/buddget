# App unificado (API + frontend) na porta 4072.
PORT=4072
NODE_ENV=development

# --- Postgres (Prisma) ------------------------------------------------------
# Com Supabase (recomendado neste projeto): Dashboard → Project Settings → Database
# - DATABASE_URL: modo "Transaction" / pooler (porta 6543), inclui ?pgbouncer=true
# - DIRECT_URL: modo "Session" ou URI direta (porta 5432), sem pgbouncer — necessário para migrate
# - Em VPS, use sempre o pooler (6543). A URI direta (5432) costuma ser bloqueada por IPv4.
# - Inclua sslmode=require (o app adiciona automaticamente se faltar).
# - NÃO use localhost na VPS. NÃO aponte para o Postgres do docker-compose em produção.
#
# Exemplo (substitua [PASSWORD] e região pelo que o painel mostrar):
# DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
# DIRECT_URL=postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require
#
# Alternativa só para desenvolvimento sem Supabase DB: Postgres local (docker compose)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/buddget
# DIRECT_URL=postgresql://postgres:postgres@localhost:5432/buddget
DATABASE_URL=
DIRECT_URL=

# Diagnóstico na VPS: GET /health/db → deve retornar {"status":"ok","database":"connected","users":N}
# Se retornar 503, a VPS não alcança o Postgres do Supabase (URL/senha/ssl/firewall).

# Passos Supabase (projeto remoto):
# 1. Copie SUPABASE_URL e chaves em Project Settings → API
# 2. Copie DATABASE_URL (Transaction pooler, :6543, ?pgbouncer=true) e DIRECT_URL (Session/Direct, :5432)
# 3. npm run db:setup
# 4. Execute supabase/storage-buckets.sql no SQL Editor
# 5. No frontend/.env: VITE_USE_MOCK_API=false e opcionalmente VITE_SUPABASE_*

JWT_SECRET=change_me_access_16c
JWT_REFRESH_SECRET=change_me_refresh_16ch
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET_IMPORTS=buddget-imports
SUPABASE_STORAGE_BUCKET_EXPORTS=buddget-exports
SUPABASE_STORAGE_BUCKET_ATTACHMENTS=buddget-attachments
BCRYPT_SALT_ROUNDS=12
