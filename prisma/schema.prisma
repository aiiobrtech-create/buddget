generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Status {
  ACTIVE
  INACTIVE
}

enum BudgetStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BudgetVersionType {
  ORIGINAL
  REVISION
  FORECAST
}

enum BudgetVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ActualSource {
  MANUAL
  IMPORT
  INTEGRATION
}

enum BudgetRequestType {
  REINFORCEMENT
  TRANSFER
  CREATION
  ADJUSTMENT
}

enum BudgetRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum UserScopeType {
  COMPANY_GROUP
  COMPANY
  CLASS
  CATEGORY
  COST_CENTER
  BUDGET_ITEM
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  email          String   @unique
  passwordHash   String   @map("password_hash")
  status         Status   @default(ACTIVE)
  allowResumo    Boolean  @default(true) @map("allow_resumo")
  companyId      String?  @map("company_id") @db.Uuid
  roleId         String   @map("role_id") @db.Uuid
  timezone       String   @default("America/Sao_Paulo")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  role           Role     @relation(fields: [roleId], references: [id])
  company        Company? @relation(fields: [companyId], references: [id])
  sessions       AuthSession[]
  auditLogs      AuditLog[]
  accessScopes   UserAccessScope[]

  @@map("users")
}

model UserAccessScope {
  userId    String        @map("user_id") @db.Uuid
  scopeType UserScopeType @map("scope_type")
  scopeId   String        @map("scope_id") @db.Uuid
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, scopeType, scopeId])
  @@index([scopeType, scopeId])
  @@map("user_access_scopes")
}

model AuthSession {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  refreshTokenHash  String   @map("refresh_token_hash")
  expiresAt         DateTime @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user              User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@map("auth_sessions")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  name        String
  module      String
  action      String
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model CompanyGroup {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  name        String
  description String?
  status      Status    @default(ACTIVE)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  companies   Company[]

  @@map("company_groups")
}

model Company {
  id              String        @id @default(uuid()) @db.Uuid
  companyGroupId  String?       @map("company_group_id") @db.Uuid
  code            String        @unique
  name            String
  legalName       String?       @map("legal_name")
  cnpj            String?       @unique
  status          Status        @default(ACTIVE)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  companyGroup    CompanyGroup? @relation(fields: [companyGroupId], references: [id])
  users           User[]
  costCenters     CostCenter[]
  budgetItems     BudgetItem[]
  ledgerClasses   BudgetCategory[]
  projects        Project[]
  budgets         Budget[]

  @@index([companyGroupId])
  @@map("companies")
}

model CostCenter {
  id            String       @id @default(uuid()) @db.Uuid
  companyId     String?      @map("company_id") @db.Uuid
  categoryId    String       @map("category_id") @db.Uuid
  code          String
  name          String
  managerUserId String?      @map("manager_user_id") @db.Uuid
  status        Status       @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  company       Company?     @relation(fields: [companyId], references: [id])
  category      BudgetClass  @relation(fields: [categoryId], references: [id])
  budgetItems   BudgetItem[]

  @@unique([categoryId, code])
  @@index([companyId, status])
  @@index([categoryId, status])
  @@map("cost_centers")
}

model BudgetItem {
  id           String       @id @default(uuid()) @db.Uuid
  costCenterId String       @map("cost_center_id") @db.Uuid
  companyId    String?      @map("company_id") @db.Uuid
  code         String
  name         String
  status       Status       @default(ACTIVE)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  costCenter   CostCenter   @relation(fields: [costCenterId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  budgetLines  BudgetLine[]
  actuals      Actual[]

  @@unique([costCenterId, code])
  @@index([companyId, status])
  @@map("budget_items")
}

model BudgetCategory {
  id           String      @id @default(uuid()) @db.Uuid
  companyId    String      @map("company_id") @db.Uuid
  code         String
  name         String
  description  String?
  displayOrder Int         @default(0) @map("display_order")
  status       Status      @default(ACTIVE)
  company      Company     @relation(fields: [companyId], references: [id])
  classes      BudgetClass[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@map("budget_classes")
}

model BudgetClass {
  id           String         @id @default(uuid()) @db.Uuid
  classId      String         @map("class_id") @db.Uuid
  code         String
  name         String
  description  String?
  displayOrder Int            @default(0) @map("display_order")
  status       Status         @default(ACTIVE)
  ledgerClass  BudgetCategory @relation(fields: [classId], references: [id])
  natures      BudgetNature[]
  costCenters  CostCenter[]

  @@unique([classId, code])
  @@map("budget_categories")
}

model BudgetNature {
  id           String      @id @default(uuid()) @db.Uuid
  classId      String      @map("class_id") @db.Uuid
  code         String
  name         String
  description  String?
  displayOrder Int         @default(0) @map("display_order")
  status       Status      @default(ACTIVE)
  class        BudgetClass @relation(fields: [classId], references: [id])

  @@unique([classId, code])
  @@map("budget_natures")
}

model Project {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  costCenterId String?  @map("cost_center_id") @db.Uuid
  code         String
  name         String
  status       Status   @default(ACTIVE)
  startDate    DateTime @map("start_date")
  endDate      DateTime? @map("end_date")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  company      Company  @relation(fields: [companyId], references: [id])

  @@unique([companyId, code])
  @@map("projects")
}

model Supplier {
  id          String   @id @default(uuid()) @db.Uuid
  legalName   String   @map("legal_name")
  tradeName   String?  @map("trade_name")
  document    String   @unique
  email       String?
  phone       String?
  status      Status   @default(ACTIVE)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("suppliers")
}

model Budget {
  id              String          @id @default(uuid()) @db.Uuid
  companyId       String          @map("company_id") @db.Uuid
  year            Int
  name            String
  description     String?
  currency        String          @default("BRL")
  status          BudgetStatus    @default(DRAFT)
  activeVersionId String?         @map("active_version_id") @db.Uuid
  createdBy       String          @map("created_by") @db.Uuid
  publishedAt     DateTime?       @map("published_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  company         Company         @relation(fields: [companyId], references: [id])
  versions        BudgetVersion[]
  forecasts       Forecast[]
  actuals         Actual[]

  @@unique([companyId, year, name])
  @@index([companyId, year, status])
  @@map("budgets")
}

model BudgetVersion {
  id            String             @id @default(uuid()) @db.Uuid
  budgetId      String             @map("budget_id") @db.Uuid
  name          String
  type          BudgetVersionType
  versionNumber Int                @map("version_number")
  status        BudgetVersionStatus @default(DRAFT)
  baseVersionId String?            @map("base_version_id") @db.Uuid
  createdBy     String             @map("created_by") @db.Uuid
  publishedBy   String?            @map("published_by") @db.Uuid
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  publishedAt   DateTime?          @map("published_at")
  budget        Budget             @relation(fields: [budgetId], references: [id])
  lines         BudgetLine[]
  forecasts     Forecast[]

  @@unique([budgetId, versionNumber])
  @@index([budgetId, status])
  @@map("budget_versions")
}

model BudgetLine {
  id             String   @id @default(uuid()) @db.Uuid
  versionId      String   @map("version_id") @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  costCenterId   String   @map("cost_center_id") @db.Uuid
  budgetItemId   String?  @map("budget_item_id") @db.Uuid
  categoryId     String   @map("category_id") @db.Uuid
  classId        String   @map("class_id") @db.Uuid
  natureId       String   @map("nature_id") @db.Uuid
  projectId      String?  @map("project_id") @db.Uuid
  supplierId     String?  @map("supplier_id") @db.Uuid
  referenceMonth Int      @map("reference_month")
  plannedAmount  Decimal  @db.Decimal(18, 2) @map("planned_amount")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  version        BudgetVersion @relation(fields: [versionId], references: [id])
  budgetItem     BudgetItem?   @relation(fields: [budgetItemId], references: [id])

  @@unique([versionId, costCenterId, categoryId, classId, natureId, referenceMonth, projectId, supplierId])
  @@index([companyId, referenceMonth])
  @@map("budget_lines")
}

model Actual {
  id             String   @id @default(uuid()) @db.Uuid
  budgetId       String?  @map("budget_id") @db.Uuid
  companyId      String   @map("company_id") @db.Uuid
  launchDate     DateTime @map("launch_date")
  competenceDate DateTime @map("competence_date")
  costCenterId   String   @map("cost_center_id") @db.Uuid
  budgetItemId   String?  @map("budget_item_id") @db.Uuid
  categoryId     String   @map("category_id") @db.Uuid
  classId        String   @map("class_id") @db.Uuid
  natureId       String   @map("nature_id") @db.Uuid
  projectId      String?  @map("project_id") @db.Uuid
  supplierId     String?  @map("supplier_id") @db.Uuid
  documentNumber String?  @map("document_number")
  description    String
  amount         Decimal  @db.Decimal(18, 2)
  source         ActualSource @default(MANUAL)
  status         Status   @default(ACTIVE)
  importBatchId  String?  @map("import_batch_id") @db.Uuid
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  budget         Budget?  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  budgetItem     BudgetItem? @relation(fields: [budgetItemId], references: [id])

  @@index([companyId, competenceDate, costCenterId])
  @@index([budgetId, competenceDate])
  @@index([budgetItemId])
  @@map("actuals")
}

model Forecast {
  id                String   @id @default(uuid()) @db.Uuid
  budgetId          String   @map("budget_id") @db.Uuid
  versionId         String   @map("version_id") @db.Uuid
  referenceMonth    Int      @map("reference_month")
  forecastAmount    Decimal  @db.Decimal(18, 2) @map("forecast_amount")
  methodology       String
  calculationMemory Json?    @map("calculation_memory")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  budget            Budget   @relation(fields: [budgetId], references: [id])
  version           BudgetVersion @relation(fields: [versionId], references: [id])

  @@unique([versionId, referenceMonth])
  @@map("forecasts")
}

model BudgetRequest {
  id             String            @id @default(uuid()) @db.Uuid
  type           BudgetRequestType
  requesterId    String            @map("requester_id") @db.Uuid
  companyId      String            @map("company_id") @db.Uuid
  costCenterId   String            @map("cost_center_id") @db.Uuid
  categoryId     String?           @map("category_id") @db.Uuid
  classId        String?           @map("class_id") @db.Uuid
  natureId       String?           @map("nature_id") @db.Uuid
  requestedAmount Decimal          @db.Decimal(18, 2) @map("requested_amount")
  justification  String
  priority       String
  status         BudgetRequestStatus @default(PENDING)
  reviewerId     String?           @map("reviewer_id") @db.Uuid
  reviewNotes    String?           @map("review_notes")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  approvedAt     DateTime?         @map("approved_at")
  rejectedAt     DateTime?         @map("rejected_at")
  canceledAt     DateTime?         @map("canceled_at")

  @@index([companyId, status, priority])
  @@map("budget_requests")
}

model Transfer {
  id                 String         @id @default(uuid()) @db.Uuid
  sourceBudgetLineId String         @map("source_budget_line_id") @db.Uuid
  targetBudgetLineId String         @map("target_budget_line_id") @db.Uuid
  amount             Decimal        @db.Decimal(18, 2)
  justification      String
  requesterId        String         @map("requester_id") @db.Uuid
  approverId         String?        @map("approver_id") @db.Uuid
  status             TransferStatus @default(PENDING)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@map("transfers")
}

model ImportBatch {
  id              String    @id @default(uuid()) @db.Uuid
  type            String
  fileName        String    @map("file_name")
  filePath        String    @map("file_path")
  storageBucket   String    @map("storage_bucket")
  totalRows       Int       @default(0) @map("total_rows")
  validRows       Int       @default(0) @map("valid_rows")
  invalidRows     Int       @default(0) @map("invalid_rows")
  status          JobStatus @default(PENDING)
  startedAt       DateTime? @map("started_at")
  finishedAt      DateTime? @map("finished_at")
  createdBy       String    @map("created_by") @db.Uuid
  errorReportPath String?   @map("error_report_path")

  @@index([type, status, startedAt])
  @@map("import_batches")
}

model ExportJob {
  id            String    @id @default(uuid()) @db.Uuid
  type          String
  filtersJson   Json      @map("filters_json")
  filePath      String?   @map("file_path")
  storageBucket String?   @map("storage_bucket")
  status        JobStatus @default(PENDING)
  createdBy     String    @map("created_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  finishedAt    DateTime? @map("finished_at")

  @@index([type, status, createdAt])
  @@map("export_jobs")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  module     String
  entity     String
  entityId   String?  @map("entity_id") @db.Uuid
  action     String
  beforeJson Json?    @map("before_json")
  afterJson  Json?    @map("after_json")
  userId     String?  @map("user_id") @db.Uuid
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id])

  @@index([module, action, createdAt])
  @@map("audit_logs")
}

model FileAttachment {
  id              String   @id @default(uuid()) @db.Uuid
  relatedEntity   String   @map("related_entity")
  relatedEntityId String   @map("related_entity_id") @db.Uuid
  bucket          String
  path            String
  fileName        String   @map("file_name")
  mimeType        String   @map("mime_type")
  size            BigInt
  uploadedBy      String   @map("uploaded_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([relatedEntity, relatedEntityId])
  @@map("file_attachments")
}

