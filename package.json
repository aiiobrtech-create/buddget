{
  "name": "buddget-backend",
  "version": "1.0.0",
  "description": "BUDDGET corporate backend",
  "main": "dist/main/server.js",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tsx watch src/main/server.ts",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev:app": "npm run dev",
    "build:frontend": "npm --prefix frontend run build",
    "build": "npm run build:frontend && tsc -p tsconfig.json",
    "start": "node dist/main/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate deploy && prisma db seed",
    "db:clean": "tsx prisma/clean-data.ts",
    "db:admin": "tsx prisma/upsert-admin.ts",
    "db:check": "tsx scripts/check-db.ts",
    "db:pooler-urls": "tsx scripts/print-pooler-urls.ts",
    "supabase:storage": "echo Execute supabase/storage-buckets.sql no SQL Editor do projeto",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:types": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/middie": "^9.0.3",
    "@fastify/static": "^8.1.1",
    "@fastify/jwt": "^9.1.0",
    "@fastify/multipart": "^9.0.3",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.49.8",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "fast-csv": "^5.0.2",
    "fastify": "^5.2.1",
    "pdfkit": "^0.16.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.12.0",
    "@types/pdfkit": "^0.17.0",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.1.2",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "wait-on": "^8.0.5"
  }
}
